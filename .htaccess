RewriteRule ^expenditure/edit/([0-9]+)$ expenditure/add_expense.php?id=$1 [L]
RewriteRule ^expenditure/save$ expenditure/save_expense.php [L,QSA]
RewriteRule ^expenditure/delete$ expenditure/save_expense.php [L,QSA]
