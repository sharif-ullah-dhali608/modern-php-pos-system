RewriteRule ^taxrates/add$ taxrates/add_taxrate.php [L]
RewriteRule ^taxrates/edit/([0-9]+)$ taxrates/add_taxrate.php?id=$1 [L]
RewriteRule ^taxrates/save$ taxrates/save_taxrate.php [L,QSA]
