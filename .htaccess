Options -MultiViews
RewriteEngine On
RewriteBase /pos

# Captcha Pretty URL
RewriteRule ^captcha$ config/captcha.php [L]

# AJAX Pretty URLs
RewriteRule ^api/stores/search$ users/fetch_stores_modal.php [L,QSA]
RewriteRule ^api/pos/products$ pos/get_products.php [L,QSA]
RewriteRule ^api/pos/save-sale$ pos/save_sale.php [L,QSA]
RewriteRule ^api/pos/add-product$ pos/ajax_add_product.php [L,QSA]
RewriteRule ^api/pos/stock-alert-count$ pos/get_stock_alert_count.php [L,QSA]
RewriteRule ^api/pos/product-details$ pos/get_product_details.php [L,QSA]
RewriteRule ^api/customers/save$ customers/save_customer.php [L,QSA]
RewriteRule ^api/customers/by-store$ customers/fetch_customers_by_store.php [L,QSA]
RewriteRule ^api/stores/save-store$ stores/save_store.php [L,QSA]
RewriteRule ^api/stores/search-currency$ stores/search_currency.php [L,QSA]
RewriteRule ^api/stores/save-settings$ stores/save_store_settings.php [L,QSA]
RewriteRule ^api/giftcard/save$ giftcard/save_giftcard.php [L,QSA]
RewriteRule ^api/giftcard/view/([0-9]+)$ giftcard/fetch_giftcard_modal.php?id=$1 [L,QSA]
RewriteRule ^api/invoices/get-data$ invoice/get_invoice_data.php [L,QSA]
RewriteRule ^api/invoices/get-items$ invoice/get_invoice_items.php [L,QSA]
RewriteRule ^api/invoices/update$ admin/update_invoice_info.php [L,QSA]
RewriteRule ^api/users/fetch-modal$ users/fetch_user_modal.php [L,QSA]
RewriteRule ^api/config/switch-store$ config/switch_store.php [L,QSA]

# --- Block Direct .php Access ---
# Show Forbidden error if a user tries to access a .php file directly.
# Pretty URLs still work via internal rewrites.
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{THE_REQUEST} \.php[\s?] [NC]
RewriteRule ^ - [F,L]

# --- Accounting Routes (Priority) ---
RewriteRule ^accounting/bank/list$ Accounting/bank_list.php [L,NC]
RewriteRule ^accounting/bank/add$ Accounting/bank_add.php [L,NC]
RewriteRule ^accounting/bank/edit/([0-9]+)$ Accounting/bank_add.php?id=$1 [L,NC]
RewriteRule ^accounting/bank/delete$ Accounting/bank_delete.php [L,NC,QSA]
RewriteRule ^accounting/bank/save$ Accounting/bank_add.php [L,NC,QSA]
RewriteRule ^accounting/bank/status$ Accounting/bank_status.php [L,NC,QSA]
RewriteRule ^accounting/income-source/list$ Accounting/income_source_list.php [L,NC]
RewriteRule ^accounting/income-source/add/?$ Accounting/add_income_source.php [L,NC]
RewriteRule ^accounting/income-source/edit/([0-9]+)/?$ Accounting/add_income_source.php?id=$1 [L,NC]
RewriteRule ^accounting/income-source/delete$ Accounting/income_source_delete.php [L,NC,QSA]
RewriteRule ^accounting/income-source/status$ Accounting/income_source_status.php [L,NC,QSA]
RewriteRule ^accounting/income-source/save$ Accounting/add_income_source.php [L,NC,QSA]
RewriteRule ^accounting/bank/transaction-list/?$ Accounting/bank_transaction_list.php [L,NC]
RewriteRule ^accounting/bank/transfer-list/?$ Accounting/bank_transfer_list.php [L,NC]
RewriteRule ^accounting/bank/balance-sheet/?$ Accounting/bank_balance_sheet.php [L,NC]
RewriteRule ^accounting/expense-monthwise/?$ Accounting/expense_monthwise.php [L,NC,QSA]
RewriteRule ^accounting/expense-monthwise/([0-9]{4})/?$ Accounting/expense_monthwise.php?year=$1 [L,NC,QSA]
RewriteRule ^accounting/expense-monthwise/([0-9]{4})/([0-9]{2})/?$ Accounting/expense_monthwise.php?year=$1&month=$2 [L,NC,QSA]
RewriteRule ^accounting/income-monthwise/?$ Accounting/income_monthwise.php [L,NC,QSA]
RewriteRule ^accounting/income-monthwise/([0-9]{4})/?$ Accounting/income_monthwise.php?year=$1 [L,NC,QSA]
RewriteRule ^accounting/income-monthwise/([0-9]{4})/([0-9]{2})/?$ Accounting/income_monthwise.php?year=$1&month=$2 [L,NC,QSA]
RewriteRule ^accounting/income-vs-expense/?$ Accounting/income_vs_expense.php [L,NC,QSA]
RewriteRule ^accounting/profit-loss/?$ Accounting/profit_loss.php [L,NC,QSA]
RewriteRule ^accounting/cashbook/?$ Accounting/cashbook.php [L,NC,QSA]
RewriteRule ^accounting/bank/transaction$ Accounting/bank_transaction_handler.php [L,NC,QSA]

# Remove trailing slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /pos/$1 [R=301,L]

# Login route
RewriteRule ^login$ signin.php [L]

# Logout route
RewriteRule ^logout$ logout.php [L]

# Footer Pages Rewrite Rules
RewriteRule ^documentation$ footer_pages/documentation.php [L]
RewriteRule ^privacy$ footer_pages/privacy.php [L]
RewriteRule ^terms$ footer_pages/terms.php [L]
RewriteRule ^guide$ footer_pages/guide.php [L]
RewriteRule ^support$ footer_pages/support.php [L]

# --- Dynamic Fallback for Module Pages ---
# Maps /folder/file to /folder/file.php automatically if the clean .php file exists.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/pos/%{REQUEST_URI}.php -f
RewriteRule ^(.+)$ $1.php [L,QSA]

# Clean URLs - Explicit Mappings (Priority)
RewriteRule ^stores/list$ stores/store_list.php [L]
RewriteRule ^stores/add$ stores/add_store.php [L]
RewriteRule ^stores/edit$ stores/add_store.php [L]
RewriteRule ^stores/settings$ stores/settings.php [L,QSA]
RewriteRule ^system/settings$ stores/settings.php [L,QSA]

RewriteRule ^currency/list$ currency/currency_list.php [L]
RewriteRule ^currency/add$ currency/add_currency.php [L]
RewriteRule ^currency/add/([0-9]+)$ currency/add_currency.php?id=$1 [L]
RewriteRule ^currency/edit/([0-9]+)$ currency/add_currency.php?id=$1 [L]
RewriteRule ^currency/save$ currency/save_currency.php [L,QSA]
RewriteRule ^currency/delete$ currency/save_currency.php [L,QSA]

RewriteRule ^payment-methods/list$ payment_methods/payment_method_list.php [L]
RewriteRule ^payment-methods/add$ payment_methods/add_payment_method.php [L]
RewriteRule ^payment-methods/save$ payment_methods/save_payment_method.php [L]
RewriteRule ^payment-methods/edit/([0-9]+)$ payment_methods/add_payment_method.php?id=$1 [L]
RewriteRule ^payment-methods/delete$ payment_methods/save_payment_method.php [L,QSA]

