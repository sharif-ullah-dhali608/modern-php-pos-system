# --- Accounting Routes (MOVED TO TOP) ---

# --- Dynamic Fallback for Module Pages (Handles up to 3 segments) ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/pos/$1.php -f
RewriteRule ^([^/.]+)/?([^/.]*)?/?([^/.]*)?$ $1${2:+/}${2}${3:+/}${3}.php [L,QSA]

# Failsafe for specific Expenditure Clean URLs
RewriteRule ^expenditure/add$ expenditure/add_expense.php [L,QSA]
RewriteRule ^expenditure/list$ expenditure/expense_list.php [L,QSA]
RewriteRule ^expenditure/edit/([0-9]+)$ expenditure/add_expense.php?id=$1 [L,QSA]
RewriteRule ^expenditure/save$ expenditure/save_expense.php [L,QSA]
RewriteRule ^expenditure/delete$ expenditure/save_expense.php [L,QSA]

